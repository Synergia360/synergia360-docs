
<!-- BEGIN: Widgets -->
{% extends "layout/layout.njk" %}
{% block content %}
    {% set pageTitle = "Blank-Page" %}
    {% set menuCategory = "Utility" %}
    {% set  wbg1  = "assets/images/all-img/widget-bg-1.png" %}
    {% set  wbg2  = "assets/images/all-img/widget-bg-3-1.png" %}
    {% set  wbg3  = "assets/images/all-img/widget-bg-3.png" %}
    {% set  wbg4  = "assets/images/all-img/widget-bg-2.png" %}
    {% set  wbg5  = "assets/images/all-img/widget-bg-4.png" %}
    {% set  wbg6  = "assets/images/all-img/widget-bg-5.png" %}
    {% set  wbg7  = "assets/images/all-img/widget-bg-6.png" %}
    {% set  wbg8  = "assets/images/all-img/widget-bg-7.png" %}
    {% set  wbg9  = "assets/images/all-img/widget-bg-8.png" %}
    {% set  vectorImage  = "assets/images/svg/widgetvector.svg" %}
    {% set  vectorImage2  = "assets/images/svg/widgetvector2.svg" %}
    {% set  svgLine  = "assets/images/svg/line.svg" %}
    {% set  svgRabit  = "assets/images/svg/rabit.svg" %}
    {% set  svgGift  = "assets/images/svg/gift.svg" %}
    {% set rabitWidget = [
    
  {
    bg: "bg-slate-900 dark:bg-slate-800"
  },
  {
    bg: "bg-primary-500"
  },
  {
    bg: "bg-success-500"
  },
  {
    bg: "bg-info-500 "
  }
    
    ] %}
    {% set griftWidget = [
    
      {
    bg: "bg-slate-900 dark:bg-slate-800"
  },
  {
    bg: "bg-primary-500"
  },
  {
    bg: "bg-success-500"
  },
  {
    bg: "bg-info-500 "
  },
  {
    bg: "bg-danger-500 "
  },
  {
    bg: "bg-warning-500 "
  }
    
    ] %}
    {% include '../templates/components/breadcrumb.njk' %}
    <div class="space-y-8">
        <div class="grid md:grid-cols-3 sm:grid-cols-2 grid-cols-1 gap-5">
            <div class="bg-no-repeat bg-cover bg-center p-4 rounded-[6px] relative" style="background-image: url({{ wbg3 }})">
                <div class="max-w-[180px]">
                    <h4 class="text-xl font-medium text-white mb-2">
                        Upgrade your Dashcode
                    </h4>
                    <p class="text-sm text-white text-opacity-80">
                        Pro plan for better results
                    </p>
                </div>
                <div class="absolute top-1/2 -translate-y-1/2 ltr:right-6 rtl:left-6 mt-2 h-12 w-12 bg-white rounded-full text-xs font-medium
                        flex flex-col items-center justify-center">
                    Now
                </div>
            </div>
            <!--  end Single -->
            <div class="bg-no-repeat bg-cover bg-center p-4 rounded-[6px] relative" style="background-image: url({{ wbg1 }})">
                <div class="max-w-[180px]">
                    <div class="text-xl font-medium text-slate-900 mb-2">
                        Upgrade your Dashcode
                    </div>
                    <p class="text-sm text-slate-800">
                        Pro plan for better results
                    </p>
                </div>
                <div class="absolute top-1/2 -translate-y-1/2 ltr:right-6 rtl:left-6 mt-2 h-12 w-12 bg-white rounded-full text-xs font-medium
                        flex flex-col items-center justify-center">
                    Now
                </div>
            </div>
            <!--  end Single -->
            <div class="bg-no-repeat bg-cover bg-center p-4 rounded-[6px] relative" style="background-image: url({{ wbg2 }})">
                <div class="max-w-[180px]">
                    <div class="text-xl font-medium text-slate-900 mb-2">
                        Upgrade your Dashcode
                    </div>
                    <p class="text-sm text-slate-800">
                        Pro plan for better results
                    </p>
                </div>
                <div class="absolute top-1/2 -translate-y-1/2 ltr:right-6 rtl:left-6 mt-2 h-12 w-12 bg-white rounded-full text-xs font-medium
                        flex flex-col items-center justify-center">
                    Now
                </div>
            </div>
            <!--  end Single -->
            <div class="bg-no-repeat bg-cover bg-center p-5 rounded-[6px] relative" style="background-image: url({{ wbg4 }})">
                <div class="max-w-[180px]">
                    <h4 class="text-xl font-medium text-white mb-2">
                        <span class="block font-normal">Good evening,</span>
                        <span class="block">Mr. Dianne Russell</span>
                    </h4>
                    <p class="text-sm text-white font-normal">
                        Welcome to Dashcode
                    </p>
                </div>
            </div>
            <!--  end Single -->
            <div
                class="bg-no-repeat bg-cover bg-center p-5 rounded-[6px] relative flex items-center"
                style="background-image: url({{ wbg5 }})">
                <div class="flex-1">
                    <div class="max-w-[180px]">
                        <div class="text-xl font-medium text-slate-900 mb-2">
                            <span class="block font-normal">Good evening,</span>
                            <span class="block">Mr. Dianne Russell</span>
                        </div>
                        <p class="text-sm text-slate-900 font-normal">
                            Welcome to Dashcode
                        </p>
                    </div>
                </div>
                <div class="flex-none">
                    <img src={{ vectorImage }} alt="" class="ml-auto">
                </div>
            </div>
            <!--  end Single -->
            <div
                class="bg-no-repeat bg-cover bg-center p-5 rounded-[6px] relative flex items-center"
                style="background-image: url({{ wbg6 }})">
                <div class="flex-1">
                    <div class="max-w-[180px]">
                        <div class="text-xl font-medium text-white dark:text-slate-800 mb-2">
                            <span class="block font-normal">Good evening,</span>
                            <span class="block">Mr. Dianne Russell</span>
                        </div>
                        <p class="text-sm text-wgite text-white dark:text-slate-800 font-normal">
                            Welcome to Dashcode
                        </p>
                    </div>
                </div>
                <div class="flex-none">
                    <img src={{ vectorImage2 }} alt="" class="ml-auto">
                </div>
            </div>
            <!--  end Single -->
            <div
                class="bg-no-repeat bg-cover bg-center px-5 py-8 rounded-[6px] relative flex items-center"
                style="background-image: url({{ wbg7 }})">
                <div class="flex-1">
                    <div class="max-w-[180px]">
                        <h4 class="text-2xl font-medium text-white mb-2">
                            <span class="block text-sm">Current balance,</span>
                            <span class="block">$34,564</span>
                        </h4>
                    </div>
                </div>
                <div class="flex-none">
                    <button class="btn-light bg-white btn-sm btn">View details</button>
                </div>
            </div>
            <!--  end Single -->
            <div
                class="bg-no-repeat bg-cover bg-center px-5 py-8 rounded-[6px] relative flex items-center"
                style="background-image: url({{ wbg8 }})">
                <div class="flex-1">
                    <div class="max-w-[180px]">
                        <h4 class="text-2xl font-medium text-slate-900 mb-2">
                            <span class="block text-sm dark:text-slate-800">
                                Current balance,
                            </span>
                            <span class="block dark:text-slate-800">$34,564</span>
                        </h4>
                    </div>
                </div>
                <div class="flex-none">
                    <button class="btn-light bg-white btn-sm btn">View details</button>
                </div>
            </div>
            <!--  end Single -->
            <div
                class="bg-no-repeat bg-cover bg-center px-5 py-8 rounded-[6px] relative flex items-center"
                style="background-image: url({{ wbg9 }})">
                <div class="flex-1">
                    <div class="max-w-[180px]">
                        <h4 class="text-2xl font-medium text-slate-900 mb-2">
                            <span class="block text-sm dark:text-slate-800">
                                Current balance,
                            </span>
                            <span class="block dark:text-slate-800">$34,564</span>
                        </h4>
                    </div>
                </div>
                <div class="flex-none">
                    <button class="btn-light bg-white btn-sm btn">View details</button>
                </div>
            </div>
        </div>
        <div class="grid md:grid-cols-4 sm:grid-cols-2 grid-cols-1 gap-5">
            {% for item in rabitWidget %}
                <div class="mt-7 p-6 relative z-[1] rounded-2xl text-white {{ item.bg }}">
                    <div class="max-w-[168px]">
                        <div class="widget-title">Unlimited Access</div>
                        <div class="text-xs font-normal">
                            Upgrade your system to business plan
                        </div>
                    </div>
                    <div class="mt-6 mb-14">
                        <button class="btn bg-white hover:bg-opacity-80 text-slate-900 btn-sm">
                            Upgrade
                        </button>
                    </div>
                    <img src={{ svgLine }} alt="" class="absolute left-0 bottom-0 w-full z-[-1]">
                    <img src={{ svgRabit }} alt="" class="absolute ltr:right-5 rtl:left-5 -bottom-4 z-[-1]">
                </div>
            {% endfor %}
        </div>
        <div class="grid lg:grid-cols-6 md:grid-cols-3 sm:grid-cols-2 grid-cols-1 gap-5">
            {% for item in griftWidget %}
                <div class="{{ item.bg }} mb-10 mt-7 p-4 relative text-center rounded-2xl text-white">
                    <img src={{ svgGift }} alt="" class="mx-auto relative -mt-[40px]">
                    <div class="max-w-[160px] mx-auto mt-6">
                        <div class="widget-title">Unlimited Access</div>
                        <div class="text-xs font-normal">
                            Upgrade your system to business plan
                        </div>
                    </div>
                    <div class="mt-6">
                        <button class="btn bg-white hover:bg-opacity-80 text-slate-900 btn-sm w-full block">
                            Upgrade
                        </button>
                    </div>
                </div>
            {% endfor %}
        </div>
        <div class="grid lg:grid-cols-6 md:grid-cols-3 sm:grid-cols-2 grid-cols-1 gap-5">
            {% for item in griftWidget %}
                <div class="{{ item.bg }} mb-10 mt-7 p-4 relative text-center rounded-2xl text-white">
                    <img src={{ svgRabit }} alt="" class="mx-auto relative -mt-[73px]">
                    <div class="max-w-[160px] mx-auto mt-6">
                        <div class="widget-title">Unlimited Access</div>
                        <div class="text-xs font-normal">
                            Upgrade your system to business plan
                        </div>
                    </div>
                    <div class="mt-6">
                        <button class="btn bg-white hover:bg-opacity-80 text-slate-900 btn-sm w-full block">
                            Upgrade
                        </button>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
<!-- END: Basic Badges -->