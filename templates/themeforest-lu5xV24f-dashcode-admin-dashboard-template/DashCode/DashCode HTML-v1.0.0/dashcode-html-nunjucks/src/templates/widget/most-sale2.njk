
<!-- BEGIN: Most Sale2 -->
{% set slaes = [
  {
    title: "Nevada",
    amount: "(80%)",
    cls: "bg-primary-500 ring-primary-500"
  },
  {
    title: "Ohio",
    amount: "(75%)",
    cls: "bg-success-500 ring-success-500"
  },
  {
    title: "Montana",
    amount: "(65%)",
    cls: "bg-info-500 ring-info-500"
  },
  {
    title: "Iowa",
    amount: "(85%)",
    cls: "bg-warning-500 ring-warning-500"
  },
  {
    title: "Arkansas",
    amount: "(90%)",
    cls: "bg-success-500 ring-success-500"
  }
] %}



<div>
      <div class="h-[290px] w-full bg-white dark:bg-slate-800 ltr:pl-10 rtl:pr-10">
            <div id="world-map" class="h-full w-full"></div>
           </div>
    <ul class="bg-slate-50 dark:bg-slate-900 rounded p-4 min-w-[184px] mt-8 flex justify-between flex-wrap items-center text-center">
        {% for item in slaes %}
   
          <li class="text-sm text-slate-600 dark:text-slate-300">
            <span class="block space-x-2 rtl:space-x-reverse">
              <span
                class="{{item.cls}} inline-flex h-[6px] w-[6px] bg-primary-500 ring-opacity-25 rounded-full ring-4"
              ></span>
              <span>{{item.title}}</span>
            </span>
            <span class="block mt-1">{{item.amount}}</span>
          </li>
        {% endfor %}
      </ul>
</div>
<!-- END: Most Sale2 -->