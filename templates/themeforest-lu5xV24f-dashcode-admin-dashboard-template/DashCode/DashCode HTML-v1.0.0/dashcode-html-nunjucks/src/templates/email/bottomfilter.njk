
<!-- BEGIN: Buttom Filter -->
{% set lists = [
  {
    name: "personal",
    value: "personal",
    icon: "heroicons:chevron-double-right"
  },
  {
    name: "Social",
    value: "social",
    icon: "heroicons:chevron-double-right"
  },
  {
    name: "Promotions",
    value: "promotions",
    icon: "heroicons:chevron-double-right"
  },
  {
    name: "Business",
    value: "business",
    icon: "heroicons:chevron-double-right"
  }
] %}
{% for item in lists %}
    <li data-status="{{ item.value }}" class="flex space-x-2 text-sm capitalize py-2 dark:text-slate-300 cursor-pointer items-center rtl:space-x-reverse email-categorie-list">
        <span class="bar-c {% if item.value === 'personal' %} bg-danger-500 ring-danger-500 {% elif item.value === 'social' %}
            bg-success-500 ring-success-500 {% elif item.value === 'promotions' %} bg-warning-500 ring-warning-500 {% elif item.value
            === 'business' %} bg-primary-500 ring-primary-500 {% endif %} inline-block h-2 w-2 rounded-full ring-opacity-30
            transition-all duration-150 "></span>
        <span class="transition duration-150">{{ item.name }}</span>
    </li>
{% endfor %}
<!-- END: Bottom Filter -->